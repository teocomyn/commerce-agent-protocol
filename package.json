{
  "name": "cap-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Commerce Agent Protocol — Middleware connecting e-commerce catalogs to AI shopping agents",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter=@cap/db db:generate",
    "db:migrate": "pnpm --filter=@cap/db db:migrate",
    "db:push": "pnpm --filter=@cap/db db:push",
    "db:studio": "pnpm --filter=@cap/db db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
