{
  "name": "@cap/api",
  "version": "0.1.0",
  "private": true,
  "description": "CAP API Server — Hono.js",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "dev:worker:enrichment": "tsx watch --env-file=../../.env src/workers/enrichment.worker.ts",
    "dev:worker:catalog": "tsx watch --env-file=../../.env src/workers/catalog-sync.worker.ts",
    "dev:workers": "concurrently -n enrich,sync -c cyan,magenta \"pnpm run dev:worker:enrichment\" \"pnpm run dev:worker:catalog\"",
    "seed": "tsx --env-file=../../.env src/scripts/seed.ts",
    "build": "tsc && tsc-alias",
    "start": "node --env-file=../../.env dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cap/db": "workspace:*",
    "@cap/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bullmq": "^5.76.4",
    "hono": "^4.12.15",
    "ioredis": "^5.4.0",
    "openai": "^4.57.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
