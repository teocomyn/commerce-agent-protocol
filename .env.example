# ==========================================
# Commerce Agent Protocol (CAP) — Environment Variables
# Copy this file to .env and fill in the values
# ==========================================

# --- Database ---
DATABASE_URL="postgresql://cap_user:cap_password@localhost:5432/cap_db"

# --- Redis ---
REDIS_URL="redis://localhost:6379"
# For Upstash (production):
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="AXXXxxx..."

# --- OpenAI ---
OPENAI_API_KEY="sk-proj-..."

# --- Shopify App ---
SHOPIFY_API_KEY="your_shopify_api_key"
SHOPIFY_API_SECRET="your_shopify_api_secret"
SHOPIFY_SCOPES="read_products,read_inventory,read_orders,write_checkouts,read_shipping"
SHOPIFY_APP_URL="https://api.commerceagent.io"

# --- Encryption ---
# 32-byte key for AES-256 encryption of Shopify tokens
ENCRYPTION_KEY="change_me_to_a_32_byte_random_key_!!"

# --- API ---
API_PORT=3000
NODE_ENV="development"

# --- Dashboard ---
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXTAUTH_SECRET="change_me_to_random_secret"
NEXTAUTH_URL="http://localhost:3001"

# --- Monitoring (optional) ---
# SENTRY_DSN="https://xxx@sentry.io/xxx"
# AXIOM_TOKEN="axm-xxx"
# AXIOM_ORG_ID="your-org"
