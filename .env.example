# ==========================================
# Commerce Agent Protocol (CAP) — Environment Variables
# Copy this file to .env and fill in the values
# ==========================================

# --- Database ---
DATABASE_URL="postgresql://cap_user:cap_password@localhost:5432/cap_db"

# --- Redis ---
REDIS_URL="redis://localhost:6379"
# For Upstash (production):
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="AXXXxxx..."

# --- OpenAI ---
OPENAI_API_KEY="sk-proj-..."

# --- Shopify App ---
SHOPIFY_API_KEY="your_shopify_api_key"
SHOPIFY_API_SECRET="your_shopify_api_secret"
# Admin scopes: catalog + orders (webhooks reconcile checkouts).
# Unauthenticated_* scopes are propagated to the Storefront access token CAP
# provisions during OAuth, and unlock the Cart API used by /v1/checkout/initiate.
SHOPIFY_SCOPES="read_products,read_inventory,read_orders,read_shipping,unauthenticated_read_product_listings,unauthenticated_read_product_inventory,unauthenticated_write_checkouts"
SHOPIFY_APP_URL="https://api.commerceagent.io"

# --- Encryption ---
# 32-byte key for AES-256 encryption of Shopify tokens
ENCRYPTION_KEY="change_me_to_a_32_byte_random_key_!!"

# --- API ---
API_PORT=3000
NODE_ENV="development"

# --- Dashboard ---
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXTAUTH_SECRET="change_me_to_random_secret"
NEXTAUTH_URL="http://localhost:3001"

# --- MCP server (stdio mode) ---
# When CAP runs as an MCP server (MCP_MODE=true), tool calls are not authenticated
# by an API key. Bind the server to a single merchant via this environment var.
# CAP_MERCHANT_ID="00000000-0000-0000-0000-000000000000"

# --- Monitoring (optional) ---
# SENTRY_DSN="https://xxx@sentry.io/xxx"
# AXIOM_TOKEN="axm-xxx"
# AXIOM_ORG_ID="your-org"
